{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "doctor-de-columna",
  "compatibility_date": "2026-05-08",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git/**",
      "scripts/**",
      "docs/**",
      "Inspiration/**",
      "Assets/Palette/**",
      "node_modules/**"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
